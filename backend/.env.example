PORT=5000

# Google Sheet ID from the sheet URL:
# https://docs.google.com/spreadsheets/d/<GOOGLE_SHEET_ID>/edit
GOOGLE_SHEET_ID=
GOOGLE_SHEET_NAME=Sheet1

# Service account credentials (Google Cloud Console)
GOOGLE_CLIENT_EMAIL=your-service-account@project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Comma-separated frontend origins allowed to call this API
ALLOWED_ORIGINS=http://localhost:3000,https://vignesh-dev.in,https://www.vignesh-dev.in

# Sheet columns (auto-created on startup):
# Timestamp | Name | Email | Phone | Message | IP | Location | Device

# Gmail notification (Google App Password, not your normal password)
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=your16charapppassword
NOTIFY_EMAIL=your@gmail.com
